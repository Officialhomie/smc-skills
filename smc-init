#!/usr/bin/env bash
# smc-init - bootstrap a Foundry smart-contract skeleton + skills
set -e

NAME=${1:-my-protocol}
DIR=${PWD}/${NAME}

if [ -d "$DIR" ]; then
  echo "Directory $DIR already exists. Aborting."
  exit 1
fi

echo "Creating project at $DIR"
mkdir -p "$DIR"
cd "$DIR"

# Init git
git init

# Try Foundry init; fall back to minimal layout
if command -v forge >/dev/null 2>&1; then
  forge init --template foundry-rs/forge-template . --force 2>/dev/null || forge init --no-git . 2>/dev/null || true
else
  mkdir -p contracts scripts test libs
fi

# Ensure canonical layout
mkdir -p contracts test scripts tools/skills ci docs build ops

# Common top-level files
cat > README.md <<'MD'
# project: SMC bootstrap
Bootstrapped by smc-init

## GitHub

- **CI** runs \`tools/skills/ci-orchestrator.sh\` (includes \`github-status.sh\` when \`gh\` is available).
- **Create repo and push**: \`SMC_GITHUB_CREATE=1 ./tools/skills/github-repo-setup.sh\` (optional, local only).
MD

cat > .gitignore <<'GI'
node_modules
lib
out
forge-std
build
GI

# create skills folder and sample skills
mkdir -p tools/skills

cat > tools/skills/format-check.sh <<'SK'
#!/usr/bin/env bash
set -e
ROOT="$(git rev-parse --show-toplevel)" || ROOT="$PWD"
cd "$ROOT"
# formatting (if installed)
if command -v prettier >/dev/null 2>&1; then
  prettier --write "**/*.{ts,js,sol,md,json}" || true
fi
if command -v solhint >/dev/null 2>&1; then
  solhint "contracts/**/*.sol" || true
fi
cat <<JSON
{
  "skill":"format-check",
  "status":"pass",
  "summary":"format/lint applied (if tools installed)",
  "artifacts":{},
  "metadata":{"runner":"local"}
}
JSON
SK
chmod +x tools/skills/format-check.sh

